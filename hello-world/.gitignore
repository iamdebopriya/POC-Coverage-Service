# Root gitignore
node_modules/
dist/
build/
coverage/
.DS_Store
.vscode/
.env
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.idea/
*.local
*.tmp
*.cache

# Ignore editor and OS files
Thumbs.db
Desktop.ini
*.swp
*.swo

# Ignore backend and frontend artifacts if not already ignored in subtree
/backend/node_modules/
/frontend/node_modules/
/backend/dist/
/frontend/dist/
/backend/build/
/frontend/build/
/backend/coverage/
/frontend/coverage/
